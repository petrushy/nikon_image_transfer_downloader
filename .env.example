# Copy to a real config and fill in. Credentials must NEVER be committed.
#
# Two ways to provide the Nikon account login:
#
#   1. Environment variables (these take precedence):
NIC_USERNAME=you@example.com
NIC_PASSWORD=your-password
#
#   2. A credentials file (YAML), default path ".env/login.txt":
#        login:
#            username: you@example.com
#            password: your-password
#      Override its location with:
# NIC_CREDENTIALS_FILE=.env/login.txt

# Where images are written (YYYY/MM/DD subfolders are created under here).
NIC_DEST_DIR=downloads

# Which files to download: all | raw | jpeg
NIC_FILE_FORMAT=all

# Service/poll mode: seconds between cloud polls.
NIC_POLL_INTERVAL=900

# Run the login browser headless (true/false). First-ever login usually needs
# headful so you can complete it manually; later refreshes can be headless.
NIC_HEADLESS=false
